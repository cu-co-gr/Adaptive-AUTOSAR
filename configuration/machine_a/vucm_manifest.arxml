<?xml version="1.0" encoding="UTF-8"?>
<!-- VUCM manifest for Machine A.
     Defines the target UCM endpoints that VUCM connects to.
     Phase 1: target = Machine B UCM (same box, port 8091).
     Phase 2: target = Machine C UCM (UNOQ, 192.168.2.96:8090). -->
<AUTOSAR xmlns="http://autosar.org/schema/r4.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://autosar.org/schema/r4.0 autosar_00050.xsd">
    <AR-PACKAGES>
        <AR-PACKAGE>
            <SHORT-NAME>VucmManifest</SHORT-NAME>
            <ELEMENTS>
                <!-- Target UCM B (Phase 1 — same physical box, port 8091) -->
                <COMMUNICATION-CLUSTER>
                    <ETHERNET-PHYSICAL-CHANNEL>
                        <SHORT-NAME>UcmBChannel</SHORT-NAME>
                        <NETWORK-ENDPOINTS>
                            <NETWORK-ENDPOINT>
                                <SHORT-NAME>UcmBTargetEP</SHORT-NAME>
                                <NETWORK-ENDPOINT-ADDRESSES>
                                    <IPV-4-CONFIGURATION>
                                        <IPV-4-ADDRESS>192.168.2.96 </IPV-4-ADDRESS>
                                    </IPV-4-CONFIGURATION>
                                </NETWORK-ENDPOINT-ADDRESSES>
                            </NETWORK-ENDPOINT>
                        </NETWORK-ENDPOINTS>
                    </ETHERNET-PHYSICAL-CHANNEL>
                    <PROTOCOL-VERSION>1</PROTOCOL-VERSION>
                </COMMUNICATION-CLUSTER>
                <ETHERNET-COMMUNICATION-CONNECTOR>
                    <SHORT-NAME>UcmBConnector</SHORT-NAME>
                    <AP-APPLICATION-ENDPOINTS>
                        <AP-APPLICATION-ENDPOINT>
                            <SHORT-NAME>UcmBTcp</SHORT-NAME>
                            <TP-CONFIGURATION>
                                <TCP-TP>
                                    <TCP-TP-PORT>
                                        <PORT-NUMBER>8090</PORT-NUMBER>
                                    </TCP-TP-PORT>
                                </TCP-TP>
                            </TP-CONFIGURATION>
                        </AP-APPLICATION-ENDPOINT>
                    </AP-APPLICATION-ENDPOINTS>
                </ETHERNET-COMMUNICATION-CONNECTOR>
            </ELEMENTS>
        </AR-PACKAGE>
    </AR-PACKAGES>
</AUTOSAR>
