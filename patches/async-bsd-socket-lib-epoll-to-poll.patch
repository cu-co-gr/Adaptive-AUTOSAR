+    Poller::~Poller() noexcept
+    {
+    }
+
+    bool Poller::tryModifyAsSenderReceiver(int connectionDescriptor)
+    {
+        // Called with mMutex already held by the caller.
+        for (auto &_pfd : mPollFds)
+        {
+            if (_pfd.fd == connectionDescriptor)
+            {
+                _pfd.events |= (POLLIN | POLLOUT);
+                return true;
+            }
+        }
+        return false;
+    }
+
+    bool Poller::TryAddListener(
+        TcpListener *tcpListener, std::function<void()> callback)
+    {
+        int _socketDescriptor = tcpListener->Descriptor();
+
+        std::lock_guard<std::mutex> _lock(mMutex);
+
+        struct pollfd _pfd;
+        _pfd.fd = _socketDescriptor;
+        _pfd.events = POLLIN;
+        _pfd.revents = 0;
+        mPollFds.push_back(_pfd);
+        mListeners[_socketDescriptor] = callback;
+
+        return true;
+    }
+
+    bool Poller::TryAddSender(
+        Communicator *communicator, std::function<void()> callback)
+    {
+        int _connectionDescriptor = communicator->Connection();
+
+        std::lock_guard<std::mutex> _lock(mMutex);
+
+        if (mReceivers.find(_connectionDescriptor) != mReceivers.end())
+        {
+            bool _result = tryModifyAsSenderReceiver(_connectionDescriptor);
+            if (_result)
+            {
+                mSenders[_connectionDescriptor] = callback;
+            }
+            return _result;
+        }
+
+        struct pollfd _pfd;
+        _pfd.fd = _connectionDescriptor;
+        _pfd.events = POLLOUT;
+        _pfd.revents = 0;
+        mPollFds.push_back(_pfd);
+        mSenders[_connectionDescriptor] = callback;
+
+        return true;
+    }
+
+    bool Poller::TryAddReceiver(
+        Communicator *communicator, std::function<void()> callback)
+    {
+        int _connectionDescriptor = communicator->Connection();
+
+        std::lock_guard<std::mutex> _lock(mMutex);
+
+        if (mSenders.find(_connectionDescriptor) != mSenders.end())
+        {
+            bool _result = tryModifyAsSenderReceiver(_connectionDescriptor);
+            if (_result)
+            {
+                mReceivers[_connectionDescriptor] = callback;
+            }
+            return _result;
+        }
+
+        struct pollfd _pfd;
+        _pfd.fd = _connectionDescriptor;
+        _pfd.events = POLLIN;
+        _pfd.revents = 0;
+        mPollFds.push_back(_pfd);
+        mReceivers[_connectionDescriptor] = callback;
+
+        return true;
+    }
+
+    bool Poller::TryRemoveListener(TcpListener *tcpListener)
+    {
+        int _socketDescriptor = tcpListener->Descriptor();
+
+        std::lock_guard<std::mutex> _lock(mMutex);
+
+        auto _it = std::find_if(
+            mPollFds.begin(), mPollFds.end(),
+            [_socketDescriptor](const struct pollfd &_p)
+            { return _p.fd == _socketDescriptor; });
+
+        if (_it == mPollFds.end())
+        {
+            return false;
+        }
+
+        mPollFds.erase(_it);
+        mListeners.erase(_socketDescriptor);
+
+        return true;
+    }
+
+    bool Poller::TryRemoveSender(Communicator *communicator)
+    {
+        int _connectionDescriptor = communicator->Connection();
+
+        std::lock_guard<std::mutex> _lock(mMutex);
+
+        auto _it = std::find_if(
+            mPollFds.begin(), mPollFds.end(),
+            [_connectionDescriptor](const struct pollfd &_p)
+            { return _p.fd == _connectionDescriptor; });
+
+        if (_it == mPollFds.end())
+        {
+            return false;
+        }
+
+        mSenders.erase(_connectionDescriptor);
+
+        if (mReceivers.count(_connectionDescriptor) > 0)
+        {
+            _it->events &= static_cast<short>(~POLLOUT);
+        }
+        else
+        {
+            mPollFds.erase(_it);
+        }
+
+        return true;
+    }
+
+    bool Poller::TryRemoveReceiver(Communicator *communicator)
+    {
+        int _connectionDescriptor = communicator->Connection();
+
+        std::lock_guard<std::mutex> _lock(mMutex);
+
+        auto _it = std::find_if(
+            mPollFds.begin(), mPollFds.end(),
+            [_connectionDescriptor](const struct pollfd &_p)
+            { return _p.fd == _connectionDescriptor; });
+
+        if (_it == mPollFds.end())
+        {
+            return false;
+        }
+
+        mReceivers.erase(_connectionDescriptor);
+
+        if (mSenders.count(_connectionDescriptor) > 0)
+        {
+            _it->events &= static_cast<short>(~POLLIN);
+        }
+        else
+        {
+            mPollFds.erase(_it);
+        }
+
+        return true;
+    }
+
+    bool Poller::TryPoll(int timeout) const
+    {
+        std::vector<struct pollfd> _snapshot;
+        {
+            std::lock_guard<std::mutex> _lock(mMutex);
+            _snapshot = mPollFds;
+        }
+
+        if (_snapshot.empty())
+        {
+            return true;
+        }
+
+        int _fdNo = poll(
+            _snapshot.data(),
+            static_cast<nfds_t>(_snapshot.size()),
+            timeout);
+
+        if (_fdNo == -1)
+        {
+            return false;
+        }
+
+        for (const struct pollfd &_pfd : _snapshot)
+        {
+            if (_pfd.revents == 0)
+            {
+                continue;
+            }
+
+            int _fd = _pfd.fd;
+            short _event = _pfd.revents;
+
+            auto _iterator = mListeners.find(_fd);
+            if (_iterator != mListeners.end())
+            {
+                (_iterator->second)();
+            }
+
+            _iterator = mSenders.find(_fd);
+            if (_iterator != mSenders.end() &&
+                (_event & POLLOUT) == POLLOUT)
+            {
+                (_iterator->second)();
+            }
+
+            _iterator = mReceivers.find(_fd);
+            if (_iterator != mReceivers.end() &&
+                (_event & POLLIN) == POLLIN)
+            {
+                (_iterator->second)();
+            }
+        }
+
+        return true;
+    }
+}
